  <types>
    <dataTypes />
    <pous>
      <pou name="FB_Filter_PT1" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="ValueIn">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Consigne brute entrée</xhtml>
              </documentation>
            </variable>
            <variable name="TimeConst">
              <type>
                <TIME />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Constante de temps du filtre</xhtml>
              </documentation>
            </variable>
            <variable name="CycleTimeS">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Temps de cycle réel en secondes</xhtml>
              </documentation>
            </variable>
            <variable name="Enable">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Active le filtre</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="ValueOut">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Consigne filtrée sortie</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="T">
              <type>
                <REAL />
              </type>
            </variable>
            <variable name="Alpha">
              <type>
                <REAL />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">T := TIME_TO_REAL(TimeConst) / 1000.0;

IF (T + CycleTimeS) &gt; 0.0 THEN
    Alpha := CycleTimeS / (T + CycleTimeS);
    ValueOut := ValueOut + Alpha * (ValueIn - ValueOut);
ELSE
    ValueOut := ValueIn;
END_IF;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
