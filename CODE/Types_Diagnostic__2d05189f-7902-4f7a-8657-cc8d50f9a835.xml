            <Single Name="TextBlobForSerialisation" Type="string">// 📋 Types pour diagnostic bus (CAN + EtherCAT)
// Réutilisables pour tout device avec Online/Operational/Error

TYPE E_DiagState :
(
    DISABLED := 0,      // Enable faux, neutralisé
    INIT := 1,          // Démarrage / scan initial
    READY := 2,         // Prêt, surveille
    MONITORING := 3,    // En surveillance active
    ERROR := 4          // Défaut présent
)
END_TYPE

// Device state: Online, Operational, Error, code défaut, phase courante, snapshot défaut
TYPE ST_DeviceDiag :
STRUCT
    Online         : BOOL;         // Device présent sur le bus
    Operational    : BOOL;         // Device actif, échange données
    Error          : BOOL;         // Défaut détecté (= ErrorId &lt;&gt; 0)
    ErrorId        : WORD;         // Bitfield défauts (16 codes max)
    State          : E_DiagState;  // Phase courante (DISABLED, READY, MONITORING, ERROR)
    StateAtError   : E_DiagState;  // Snapshot figé au moment du défaut
END_STRUCT
END_TYPE</Single>
