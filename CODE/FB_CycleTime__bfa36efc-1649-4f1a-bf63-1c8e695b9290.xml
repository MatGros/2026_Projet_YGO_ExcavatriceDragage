  <types>
    <dataTypes />
    <pous>
      <pou name="FB_CycleTime" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="DefaultValueS">
              <type>
                <REAL />
              </type>
              <initialValue>
                <simpleValue value="0.004" />
              </initialValue>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Valeur de secours (Ex: MainTask = 20ms -&gt; 0.020)</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="CycleTimeS">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Temps écoulé réel (Secondes)</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="TimeCurrent">
              <type>
                <TIME />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Temps système actuel</xhtml>
              </documentation>
            </variable>
            <variable name="TimeLast">
              <type>
                <TIME />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Empreinte du cycle précédent</xhtml>
              </documentation>
            </variable>
            <variable name="DeltaTimeMs">
              <type>
                <UDINT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Écart brut calculé</xhtml>
              </documentation>
            </variable>
            <variable name="InitDone">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Drapeau d'initialisation</xhtml>
              </documentation>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 1. ACQUISITION DU TEMPS SYSTÈME
TimeCurrent := TIME();

// 2. INITIALISATION UNIQUE AU PREMIER CYCLE
IF NOT InitDone THEN
    TimeLast := TimeCurrent; // ◄ Fixé ici pour éviter un calcul faussé au cycle 2
    InitDone := TRUE;
    CycleTimeS := DefaultValueS;
    RETURN;
END_IF;

// 3. CALCUL DU DELTA EN MILLISECONDES
DeltaTimeMs := TIME_TO_UDINT(TimeCurrent - TimeLast);

// 4. CONVERSION ET CHARGE DE SECOURS
IF DeltaTimeMs &gt; 0 THEN
    CycleTimeS := UDINT_TO_REAL(DeltaTimeMs) / 1000.0;
ELSE
    CycleTimeS := DefaultValueS;
END_IF;

// 5. ARCHIVAGE POUR LE PROCHAIN CYCLE
TimeLast := TimeCurrent;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
