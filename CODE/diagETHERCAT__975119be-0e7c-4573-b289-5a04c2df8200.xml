  <types>
    <dataTypes />
    <pous>
      <pou name="diagETHERCAT" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="Enable">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Active la surveillance</xhtml>
              </documentation>
            </variable>
            <variable name="Reset">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Acquittement des défauts</xhtml>
              </documentation>
            </variable>
            <variable name="WcState">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Working Counter (FALSE = Trame valide/En ligne)</xhtml>
              </documentation>
            </variable>
            <variable name="SlaveState">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> État interne esclave (8 = OP / Operational)</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="Ready">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Bloc actif</xhtml>
              </documentation>
            </variable>
            <variable name="Online">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Esclave présent et répond</xhtml>
              </documentation>
            </variable>
            <variable name="Operational">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Esclave en mode OP (données valides)</xhtml>
              </documentation>
            </variable>
            <variable name="Error">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Défaut actif</xhtml>
              </documentation>
            </variable>
            <variable name="ErrorId">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Code d'erreur</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <addData>
            <data name="http://www.3s-software.com/plcopenxml/attributes" handleUnknown="implementation">
              <Attributes>
                <Attribute Name="object_name" Value="diagETHERCAT" />
              </Attributes>
            </data>
          </addData>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 🛑 1. GATE DE SÉCURITÉ
IF NOT Enable THEN
    Ready := FALSE;
    Online := FALSE;
    Operational := FALSE;
    Error := FALSE;
    ErrorId := 16#0000;
    RETURN;
END_IF;

Ready := TRUE;

// 🔑 2. RESET DÉFAUT
IF Reset AND Error THEN
    Error := FALSE;
    ErrorId := 16#0000;
END_IF;

// 🔍 3. DIAGNOSTIC ETHERCAT
// WcState à FALSE signifie que le maître communique physiquement avec le nœud
Online := NOT WcState; 

// L'état 8 en EtherCAT correspond à l'état "Operational" (échanges cycliques actifs)
Operational := Online AND (SlaveState = 8);

// ⚠️ 4. GESTION DES ERREURS
IF NOT Online THEN
    Error := TRUE;
    ErrorId := 16#0010; // Code : Perte de communication physique
ELSIF NOT Operational THEN
    Error := TRUE;
    ErrorId := 16#0011; // Code : Esclave hors mode Operational (Pre-Op, Safe-Op, etc.)
END_IF;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
