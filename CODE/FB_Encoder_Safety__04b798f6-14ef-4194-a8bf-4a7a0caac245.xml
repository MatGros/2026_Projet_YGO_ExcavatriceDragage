  <types>
    <dataTypes />
    <pous>
      <pou name="FB_Encoder_Safety" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="RawSpeed">
              <type>
                <INT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Vitesse brute du bus (%IW6)</xhtml>
              </documentation>
            </variable>
            <variable name="MaxSpeedLimit">
              <type>
                <INT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Seuil critique de survitesse (en pts de vitesse)</xhtml>
              </documentation>
            </variable>
            <variable name="SpeedFilterTime">
              <type>
                <TIME />
              </type>
              <initialValue>
                <simpleValue value="TIME#100ms" />
              </initialValue>
            </variable>
            <variable name="CycleTimeS">
              <type>
                <REAL />
              </type>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="OverspeedTrip">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Ordre d'arrêt d'urgence / Freinage d'urgence</xhtml>
              </documentation>
            </variable>
            <variable name="FilteredSpeed">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Vitesse lissée pour monitoring IHM</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="Filter">
              <type>
                <derived name="FB_Filter_PT1" />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Réutilisation du filtre POO</xhtml>
              </documentation>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 1. Filtrage de la vitesse brute pour éviter les déclenchements intempestifs sur pic de com
Filter(ValueIn := INT_TO_REAL(RawSpeed), TimeConst := SpeedFilterTime, CycleTimeS := CycleTimeS);
FilteredSpeed := Filter.ValueOut;

// 2. Surveillance du seuil critique (survitesse positive ou négative)
IF ABS(FilteredSpeed) &gt;= INT_TO_REAL(MaxSpeedLimit) THEN
    OverspeedTrip := TRUE; // Interlock / Trip à verrouiller dans votre sécurité machine
ELSE
    OverspeedTrip := FALSE;
END_IF</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
