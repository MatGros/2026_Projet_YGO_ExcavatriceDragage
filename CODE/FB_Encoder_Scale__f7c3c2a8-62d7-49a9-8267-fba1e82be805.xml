  <types>
    <dataTypes />
    <pous>
      <pou name="FB_Encoder_Scale" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="CurrentRawPos">
              <type>
                <UDINT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Valeur brute synchrone (%ID2)</xhtml>
              </documentation>
            </variable>
            <variable name="OffsetValueB">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Le "b" de l'équation (décalage en mètres)</xhtml>
              </documentation>
            </variable>
            <variable name="EnableTeach">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Active le mode calibration</xhtml>
              </documentation>
            </variable>
            <variable name="StartTeachPos">
              <type>
                <UDINT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Capture de la position brute au point A</xhtml>
              </documentation>
            </variable>
            <variable name="EndTeachPos">
              <type>
                <UDINT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Capture de la position brute au point B</xhtml>
              </documentation>
            </variable>
            <variable name="RealDistMeters">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Distance réelle mesurée au mètre ruban entre A et B</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <inOutVars>
            <variable name="PulsePerMeter">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Le "a" de l'équation (Pulsations / mètre)</xhtml>
              </documentation>
            </variable>
          </inOutVars>
          <outputVars>
            <variable name="PositionMeters">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> La sortie finale f(x) = ax + b</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="DeltaPulses">
              <type>
                <REAL />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 1. Mode Teach : Calcul automatique du coefficient de mise à l'échelle (a)
IF EnableTeach AND RealDistMeters &gt; 0.001 THEN
    DeltaPulses := UDINT_TO_REAL(EndTeachPos) - UDINT_TO_REAL(StartTeachPos);
    IF ABS(DeltaPulses) &gt; 0.0 THEN
        // Calcul du ratio : impulsions par mètre
        PulsePerMeter := ABS(DeltaPulses) / RealDistMeters;
    END_IF
END_IF

// 2. Application de la formule affine y = ax + b
// Sécurité : évite la division par zéro si le ratio n'est pas configuré
IF PulsePerMeter &gt; 0.001 THEN
    PositionMeters := (UDINT_TO_REAL(CurrentRawPos) / PulsePerMeter) + OffsetValueB;
ELSE
    PositionMeters := 0.0;
END_IF</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
