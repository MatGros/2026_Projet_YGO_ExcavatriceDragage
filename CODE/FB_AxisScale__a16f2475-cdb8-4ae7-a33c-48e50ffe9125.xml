  <types>
    <dataTypes />
    <pous>
      <pou name="FB_AxisScale" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="RawIn">
              <type>
                <INT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Valeur brute (0..10000)</xhtml>
              </documentation>
            </variable>
            <variable name="Neutral">
              <type>
                <INT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Point milieu calibré</xhtml>
              </documentation>
            </variable>
            <variable name="Deadband">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Zone morte en %</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="OutPct">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Valeur finale (-100.0..100.0)</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="Delta">
              <type>
                <REAL />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">IF RawIn &gt;= Neutral THEN
    Delta := INT_TO_REAL(10000 - Neutral);
    IF Delta &gt; 0.0 THEN
        OutPct := (INT_TO_REAL(RawIn - Neutral) / Delta) * 100.0;
    ELSE
        OutPct := 0.0;
    END_IF;
ELSE
    Delta := INT_TO_REAL(Neutral);
    IF Delta &gt; 0.0 THEN
        OutPct := (INT_TO_REAL(RawIn - Neutral) / Delta) * 100.0;
    ELSE
        OutPct := 0.0;
    END_IF;
END_IF;

IF ABS(OutPct) &lt;= Deadband THEN
    OutPct := 0.0;
END_IF;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
