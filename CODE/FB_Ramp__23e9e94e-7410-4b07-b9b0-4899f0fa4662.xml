  <types>
    <dataTypes />
    <pous>
      <pou name="FB_Ramp" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="Target">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Cible visée</xhtml>
              </documentation>
            </variable>
            <variable name="AccelRate">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Taux d'accélération (%/s)</xhtml>
              </documentation>
            </variable>
            <variable name="DecelRate">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Taux de décélération (%/s)</xhtml>
              </documentation>
            </variable>
            <variable name="CycleTimeS">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Temps de cycle réel en secondes</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="Current">
              <type>
                <REAL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Valeur courante amortie</xhtml>
              </documentation>
            </variable>
          </outputVars>
          <localVars>
            <variable name="StepX">
              <type>
                <REAL />
              </type>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// Détection du comportement (Accélération vs Décélération)
IF (Target &gt; 0.0 AND Target &gt; Current) OR (Target &lt; 0.0 AND Target &lt; Current) THEN
    StepX := AccelRate * CycleTimeS; // S'éloigne du zéro
ELSE
    StepX := DecelRate * CycleTimeS; // Retourne vers le zéro
END_IF;

// Application de la rampe
IF Current &lt; Target THEN
    Current := Current + StepX;
    IF Current &gt; Target THEN Current := Target; END_IF;
ELSIF Current &gt; Target THEN
    Current := Current - StepX;
    IF Current &lt; Target THEN Current := Target; END_IF;
END_IF;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
