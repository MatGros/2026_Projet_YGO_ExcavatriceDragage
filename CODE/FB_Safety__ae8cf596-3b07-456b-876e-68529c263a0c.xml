  <types>
    <dataTypes />
    <pous>
      <pou name="FB_Safety" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="Enable">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Active la surveillance</xhtml>
              </documentation>
            </variable>
            <variable name="Reset">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Front d'acquittement des défauts</xhtml>
              </documentation>
            </variable>
            <variable name="EStopArmed">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Entrée TOR fail-safe (TRUE = OK, FALSE = Déclenché)</xhtml>
              </documentation>
            </variable>
            <variable name="CanOnline">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Trame com active (TRUE = OK)</xhtml>
              </documentation>
            </variable>
            <variable name="CanOperational">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Nœud en marche (TRUE = OK)</xhtml>
              </documentation>
            </variable>
            <variable name="EthercatOk">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Bus EtherCAT sain (TRUE = OK)</xhtml>
              </documentation>
            </variable>
          </inputVars>
          <outputVars>
            <variable name="Ready">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Logique de sécurité opérationnelle</xhtml>
              </documentation>
            </variable>
            <variable name="SafeStop">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Ordre d'arrêt absolu (TRUE = STOP IMMÉDIAT)</xhtml>
              </documentation>
            </variable>
            <variable name="SafetyOk">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Feu vert global (TRUE = Autorisation de bouger)</xhtml>
              </documentation>
            </variable>
            <variable name="Error">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Présence anomalie sécurité</xhtml>
              </documentation>
            </variable>
            <variable name="ErrorId">
              <type>
                <WORD />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Code bitfield de la cause du déclenchement</xhtml>
              </documentation>
            </variable>
          </outputVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 🛑 1. GATE AUTOMATE
IF NOT Enable THEN
    Ready := FALSE;
    SafeStop := TRUE;             // Sécurité par défaut : arrêt forcé
    SafetyOk := FALSE;
    RETURN;
END_IF;

Ready := TRUE;

// 🔑 2. RESET DÉFAUTS
IF Reset AND Error THEN
    Error := FALSE;
    ErrorId := 16#0000;
END_IF;

// 🛡️ 3. LOGIQUE FAIL-SAFE (Perte de signal = Danger)
IF NOT EStopArmed THEN
    ErrorId := 16#0001;           // Code : Arrêt d'urgence activé
ELSIF NOT CanOnline OR NOT CanOperational THEN
    ErrorId := 16#0002;           // Code : Liaison Joystick perdue
ELSIF NOT EthercatOk THEN
    ErrorId := 16#0004;           // Code : Bus EtherCAT en faute
END_IF;

// 📤 4. ARBITRAGE DES SORTIES TRANSVERSES
Error := (ErrorId &lt;&gt; 16#0000);

// SafeStop est l'actionneur logiciel (TRUE = On coupe tout)
SafeStop := Error;

// SafetyOk est le feu vert (TRUE = Tout est sain)
SafetyOk := NOT Error;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
