  <types>
    <dataTypes />
    <pous>
      <pou name="diagCAN" pouType="program">
        <interface>
          <localVars>
            <variable name="BusState">
              <type>
                <derived name="BUS_STATE" />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Bus &amp; Device states</xhtml>
              </documentation>
            </variable>
            <variable name="DeviceState">
              <type>
                <derived name="DEVICE_STATE" />
              </type>
            </variable>
            <variable name="BusError">
              <type>
                <INT />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Internal function execution errors (0 = NO_ERROR)</xhtml>
              </documentation>
            </variable>
            <variable name="DeviceError">
              <type>
                <INT />
              </type>
            </variable>
            <variable name="BusDiagAvailable">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Diagnosis status flags</xhtml>
              </documentation>
            </variable>
            <variable name="DevDiagAvailable">
              <type>
                <BOOL />
              </type>
            </variable>
            <variable name="IsOnline">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Device is physically present on the bus</xhtml>
              </documentation>
            </variable>
            <variable name="IsOperational">
              <type>
                <BOOL />
              </type>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Device is running and actively processing I/O (PDO)</xhtml>
              </documentation>
            </variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">// 1. Get CAN bus logic status
BusState := CANopen_Manager.GetBusState(
    xDiagnosisInfoAvailable =&gt; BusDiagAvailable, 
    eError =&gt; BusError
);

// 2. Get Joystick node status
DeviceState := JOY1_JOYSTICK_MCB560_CO4201A.GetDeviceState(
    xDiagnosisInfoAvailable =&gt; DevDiagAvailable, 
    eError =&gt; DeviceError
);

// 3. Evaluate if device is physically connected/found
IF DeviceState &lt;&gt; DEVICE_STATE.NOT_FOUND THEN
    IsOnline := TRUE;
ELSE
    IsOnline := FALSE;
END_IF;

// 4. Evaluate if device is actively Operational (NMT Operational / Running)
IF DeviceState = DEVICE_STATE.RUNNING THEN
    IsOperational := TRUE;
ELSE
    IsOperational := FALSE; 
    // (If FALSE, it might be stopped, pre-operational, or disconnected)
END_IF;</xhtml>
          </ST>
        </body>
        <addData />
      </pou>
    </pous>
