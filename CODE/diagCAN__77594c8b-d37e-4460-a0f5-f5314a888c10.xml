            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM diagCAN
VAR
    // Bus &amp; Device states
    BusState         : BUS_STATE;
    DeviceState      : DEVICE_STATE;
    
    // Internal function execution errors (0 = NO_ERROR)
    BusError         : INT;
    DeviceError      : INT;
    
    // Diagnosis status flags
    BusDiagAvailable : BOOL;
    DevDiagAvailable : BOOL;
    
    // Status flags
    IsOnline         : BOOL; // Device is physically present on the bus
    IsOperational    : BOOL; // Device is running and actively processing I/O (PDO)
END_VAR</Single>
