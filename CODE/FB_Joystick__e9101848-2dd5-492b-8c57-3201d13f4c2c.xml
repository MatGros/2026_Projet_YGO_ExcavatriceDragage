              <type>
                <INT />
              </type>
              <initialValue>
                <simpleValue value="5000" />
              </initialValue>
              <documentation>
                <xhtml xmlns="http://www.w3.org/1999/xhtml"> Mémoire persistante Y</xhtml>
              </documentation>
            </variable>
