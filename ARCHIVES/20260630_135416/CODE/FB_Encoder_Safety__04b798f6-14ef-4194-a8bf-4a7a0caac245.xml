            <Single Name="TextBlobForSerialisation" Type="string">// 1. Filtrage de la vitesse brute pour éviter les déclenchements intempestifs sur pic de com
Filter(ValueIn := INT_TO_REAL(RawSpeed), TimeConst := SpeedFilterTime, CycleTimeS := CycleTimeS);
FilteredSpeed := Filter.ValueOut;

// 2. Surveillance du seuil critique (survitesse positive ou négative)
IF ABS(FilteredSpeed) &gt;= INT_TO_REAL(MaxSpeedLimit) THEN
    OverspeedTrip := TRUE; // Interlock / Trip à verrouiller dans votre sécurité machine
ELSE
    OverspeedTrip := FALSE;
END_IF</Single>
