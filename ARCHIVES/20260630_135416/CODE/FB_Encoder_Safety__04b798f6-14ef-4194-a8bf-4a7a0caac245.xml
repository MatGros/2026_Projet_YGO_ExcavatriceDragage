            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_Encoder_Safety
VAR_INPUT
    RawSpeed        : INT;  // Vitesse brute du bus (%IW6)
    MaxSpeedLimit   : INT;  // Seuil critique de survitesse (en pts de vitesse)
    SpeedFilterTime : TIME := T#100ms;
    CycleTimeS      : REAL;
END_VAR
VAR_OUTPUT
    OverspeedTrip   : BOOL; // Ordre d'arrêt d'urgence / Freinage d'urgence
    FilteredSpeed   : REAL; // Vitesse lissée pour monitoring IHM
END_VAR
VAR
    Filter          : FB_Filter_PT1; // Réutilisation du filtre POO
END_VAR</Single>
