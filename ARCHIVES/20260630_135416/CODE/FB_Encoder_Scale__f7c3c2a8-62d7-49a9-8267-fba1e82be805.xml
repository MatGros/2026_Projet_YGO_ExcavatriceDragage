            <Single Name="TextBlobForSerialisation" Type="string">// 1. Mode Teach : Calcul automatique du coefficient de mise à l'échelle (a)
IF EnableTeach AND RealDistMeters &gt; 0.001 THEN
    DeltaPulses := UDINT_TO_REAL(EndTeachPos) - UDINT_TO_REAL(StartTeachPos);
    IF ABS(DeltaPulses) &gt; 0.0 THEN
        // Calcul du ratio : impulsions par mètre
        PulsePerMeter := ABS(DeltaPulses) / RealDistMeters;
    END_IF
END_IF

// 2. Application de la formule affine y = ax + b
// Sécurité : évite la division par zéro si le ratio n'est pas configuré
IF PulsePerMeter &gt; 0.001 THEN
    PositionMeters := (UDINT_TO_REAL(CurrentRawPos) / PulsePerMeter) + OffsetValueB;
ELSE
    PositionMeters := 0.0;
END_IF</Single>
