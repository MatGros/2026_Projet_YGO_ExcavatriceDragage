            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_Encoder_Scale
VAR_INPUT
    CurrentRawPos : UDINT;        // Valeur brute synchrone (%ID2)
    OffsetValueB  : REAL;         // Le "b" de l'équation (décalage en mètres)
    
    (* Mode Teach / Calibration assistée *)
    EnableTeach   : BOOL;         // Active le mode calibration
    StartTeachPos : UDINT;        // Capture de la position brute au point A
    EndTeachPos   : UDINT;        // Capture de la position brute au point B
    RealDistMeters: REAL;         // Distance réelle mesurée au mètre ruban entre A et B
END_VAR
VAR_IN_OUT
    PulsePerMeter : REAL;         // Le "a" de l'équation (Pulsations / mètre)
END_VAR
VAR_OUTPUT
    PositionMeters: REAL;         // La sortie finale f(x) = ax + b
END_VAR
VAR
    DeltaPulses   : REAL;
END_VAR</Single>
