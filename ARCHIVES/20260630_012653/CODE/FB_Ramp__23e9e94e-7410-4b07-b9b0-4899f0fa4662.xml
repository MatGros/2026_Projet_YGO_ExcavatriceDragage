            <Single Name="TextBlobForSerialisation" Type="string">(* modif *)
// Détection du comportement (Accélération vs Décélération)
IF (Target &gt; 0.0 AND Target &gt; Current) OR (Target &lt; 0.0 AND Target &lt; Current) THEN
    StepX := AccelRate * CycleTimeS; // S'éloigne du zéro
ELSE
    StepX := DecelRate * CycleTimeS; // Retourne vers le zéro
END_IF;

// Application de la rampe
IF Current &lt; Target THEN
    Current := Current + StepX;
    IF Current &gt; Target THEN Current := Target; END_IF;
ELSIF Current &gt; Target THEN
    Current := Current - StepX;
    IF Current &lt; Target THEN Current := Target; END_IF;
END_IF;</Single>
